{
 "doctype": "DocType",
 "name": "Pattern Template",
 "module": "Textile",
 "is_custom": 0,
 "is_submittable": 0,
 "is_tree": 0,
 "is_child_table": 0,
 "is_table": 0,
 "is_single": 0,
 "editable_grid": 1,
 "autoname": "naming_series:",
 "naming_series": "PT-.YYYY.-.####",
 "title_field": "template_name",
 "track_changes": 1,
 "fields": [
  {
   "fieldname": "naming_series",
   "fieldtype": "Select",
   "label": "Series",
   "options": "PT-.YYYY.-.####",
   "default": "PT-.YYYY.-.####",
   "reqd": 1,
   "hidden": 1
  },
  {
   "fieldname": "template_name",
   "fieldtype": "Data",
   "label": "Template Name",
   "reqd": 1,
   "unique": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "fabric_item",
   "fieldtype": "Link",
   "label": "Fabric Item",
   "options": "Item",
   "description": "The fabric item this pattern is designed for"
  },
  {
   "fieldname": "section_break_pieces",
   "fieldtype": "Section Break",
   "label": "Pattern Pieces"
  },
  {
   "fieldname": "pieces",
   "fieldtype": "Table",
   "label": "Pattern Pieces",
   "options": "Pattern Piece",
   "reqd": 1,
   "description": "Define each piece's dimensions and quantity needed"
  },
  {
   "fieldname": "section_break_layout",
   "fieldtype": "Section Break",
   "label": "Layout Preview",
   "collapsible": 1
  },
  {
   "fieldname": "layout_svg",
   "fieldtype": "Code",
   "label": "Layout SVG",
   "options": "HTML",
   "description": "SVG representation of the cutting layout (auto-generated)"
  },
  {
   "fieldname": "total_area_sq_m",
   "fieldtype": "Float",
   "label": "Total Area (sq m)",
   "read_only": 1,
   "description": "Total area of all pieces combined"
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1, "write": 1, "create": 1, "delete": 1,
   "email": 1, "print": 1, "import": 1, "export": 1, "report": 1, "share": 1
  },
  {
   "role": "Job Work Manager",
   "read": 1, "write": 1, "create": 1, "delete": 1,
   "email": 1, "print": 1, "import": 1, "export": 1, "report": 1, "share": 1
  },
  {
   "role": "All",
   "read": 1
  }
 ],
 "sort_field": "modified",
 "sort_order": "DESC"
}
