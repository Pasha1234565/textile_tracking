  {
   "fieldname": "wastage_remarks",
   "fieldtype": "Small Text",
   "label": "Wastage Remarks"
  },
  {
   "fieldname": "amended_from",
   "fieldtype": "Link",
   "label": "Amended From",
   "options": "Fabric Roll",
   "no_copy": 1,
   "hidden": 1,
   "print_hide": 1,
   "read_only": 1,
   "search_index": 1
  }
 ],
