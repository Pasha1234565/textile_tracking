  {
   "fieldname": "garment_type",
   "fieldtype": "Select",
   "label": "Garment Type",
   "options": "\nShirt\nT-Shirt\nBlouse\nKurta\nSaree\nSuit Set\nTrouser / Pant\nSkirt",
