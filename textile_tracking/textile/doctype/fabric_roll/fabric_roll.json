   "description": "The finished fabric item code"
  },
  {
   "fieldname": "production_stage",
   "fieldtype": "Select",
   "label": "Production Stage",
   "options": "Grey Fabric\nBleached\nDyed\nPrinted\nFinished\nProcessed",
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "traceability_section",
   "fieldtype": "Section Break",
   "label": "Traceability"
  },
  {
   "fieldname": "raw_material_batch",
   "fieldtype": "Link",
   "label": "Raw Material Batch",
