  {
   "fieldname": "column_break_measure",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "width_cm",
   "fieldtype": "Float",
   "label": "Width (CM)",
   "description": "Fabric width in centimeters"
  },
  {
   "fieldname": "weight_kg",
   "fieldtype": "Float",
   "label": "Weight (KG)",
   "description": "Gross weight in kilograms"
  },
  {
   "fieldname": "quality_section",
   "fieldtype": "Section Break",
   "label": "Quality"
  },
  {
   "fieldname": "grade",
   "fieldtype": "Select",
   "label": "Grade",
   "options": "Premium\nA\nB\nC\nReject",
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "column_break_quality",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "quality_status",
   "fieldtype": "Select",
   "label": "Quality Status",
   "options": "Passed\nQuarantine\nFailed"
  },
  {
   "fieldname": "production_date",
   "fieldtype": "Date",
   "label": "Production Date",
   "default": "Today",
   "in_list_view": 1
  },
  {
   "fieldname": "daily_production_section",
   "fieldtype": "Section Break",
   "label": "Daily Production Tracking"
  },
  {
   "fieldname": "daily_production",
   "fieldtype": "Table",
   "label": "Daily Production Entries",
   "options": "Fabric Roll Daily Production",
   "description": "Record daily garment production from this roll"
  },
  {
   "fieldname": "digital_passport_section",
   "fieldtype": "Section Break",
   "label": "Digital Product Passport",
   "collapsible": 1
