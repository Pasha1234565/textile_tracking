 "title_field": "roll_number",
 "track_changes": 1,
 "track_views": 1,
 "fields": [
  {
   "fieldname": "naming_series",
   "fieldtype": "Select",
   "label": "Series",
   "options": "FBR-.YYYY.-.####",
   "default": "FBR-.YYYY.-.####",
   "reqd": 1,
   "hidden": 1
  },
  {
   "fieldname": "roll_number",
   "fieldtype": "Data",
   "label": "Roll Number",
   "reqd": 1,
   "unique": 1,
   "in_list_view": 1,
   "in_standard_filter": 1,
   "search_index": 1,
   "description": "Physical roll identifier (e.g., FBR-2407-001)"
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "In Production\nCompleted\nQuarantine\nDispatched",
   "default": "In Production",
   "reqd": 1,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "source_item",
   "fieldtype": "Link",
   "label": "Fabric Item",
   "options": "Item",
