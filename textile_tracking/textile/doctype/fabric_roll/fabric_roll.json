 "module": "Textile",
 "is_custom": 0,
 "is_submittable": 1,
 "is_virtual": 0,
 "is_tree": 0,
 "is_child_table": 0,
 "is_table": 0,
 "is_single": 0,
 "editable_grid": 1,
 "autoname": "naming_series:",
