  {
   "fieldname": "qr_code_text",
   "fieldtype": "Data",
   "label": "Passport QR URL",
   "read_only": 1,
   "description": "Auto-generated URL for the Digital Product Passport page"
  },
  {
   "fieldname": "process_history_section",
   "fieldtype": "Section Break",
   "label": "Process History"
  },
  {
   "fieldname": "process_history",
   "fieldtype": "Table",
   "label": "Process History",
   "options": "Process History Entry",
   "description": "Chronological record of all processes applied to this roll"
  },
  {
   "fieldname": "production_summary_section",
   "fieldtype": "Section Break",
   "label": "Production Summary & Wastage"
  },
  {
   "fieldname": "actual_total_produced",
   "fieldtype": "Float",
   "label": "Actual Garments Produced",
   "read_only": 1,
   "description": "Sum of all daily production entries"
  },
  {
   "fieldname": "column_break_wastage",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "wastage_percentage",
   "fieldtype": "Percent",
   "label": "Wastage %",
   "read_only": 1,
   "description": "((Estimated - Actual) / Estimated) × 100"
